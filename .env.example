# Plato Backend Config

# JWT secret (change this!)
JWT_SECRET=plato-super-secret-change-in-production

# Optional: USDA API key (get free key at https://fdc.nal.usda.gov/api-guide.html)
# Without this, uses DEMO_KEY which is rate-limited to 30 requests/hour
USDA_API_KEY=DEMO_KEY

# Port (Railway sets this automatically)
PORT=3000

# Stripe (future - for premium subscriptions)
# STRIPE_SECRET_KEY=sk_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_...
# VITE_PREMIUM_CHECKOUT_URL=https://...

# Backend API URL (Railway deployment)
# Set this in Vercel env vars to point to your Railway backend
VITE_API_URL=https://your-backend.up.railway.app
